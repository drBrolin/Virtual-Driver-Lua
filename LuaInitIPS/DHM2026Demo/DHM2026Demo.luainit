function write_vision(condition_id, participant_id, visionNr, visionEval)
	local line = string.format(
		'%d,%d,%d,%f\n',
		condition_id,
		participant_id,
		visionNr,
		visionEval
	)

	vision_buffer[#vision_buffer + 1] = line

	if #vision_buffer >= BUFFER_LIMIT then
		flush_vision()
	end
end

function flush_vision()
	visionfile:write(table.concat(vision_buffer))
	vision_buffer = {}
end

function read_integer_csv(filename)
    local values = {}

    local file, err = io.open(filename, "r")
    if not file then
        error("Could not open file: " .. err)
    end

    for line in file:lines() do
        -- Trim whitespace
        line = line:match("^%s*(.-)%s*$")

        if line ~= "" then
            local num = tonumber(line)

            if not num or math.floor(num) ~= num then
                file:close()
                error("Invalid integer value in file: " .. line)
            end

            values[#values + 1] = num
        end
    end

    file:close()
    return values
end

function read_condition_participant_csv(filename)
    local data = {}

    local file, err = io.open(filename, "r")
    if not file then
        error("Could not open file: " .. err)
    end

    for line in file:lines() do
        -- trim whitespace
        line = line:match("^%s*(.-)%s*$")

        if line ~= "" then
            -- match two comma-separated values
            local c, p = line:match("([^,]+),([^,]+)")

            if not c or not p then
                file:close()
                error("Invalid CSV format in line: " .. line)
            end

            c = tonumber(c)
            p = tonumber(p)

            if not c or not p then
                file:close()
                error("Non-numeric value in line: " .. line)
            end

            data[#data + 1] = {c, p}
        end
    end

    file:close()
    return data
end